# WikiMind environment configuration
# Copy to .env and fill in your values.
# All variables are optional — sensible defaults are built in.

# ── Core ──────────────────────────────────────────────────────────────────────
# WIKIMIND_DATA_DIR=~/.wikimind
# WIKIMIND_GATEWAY_PORT=7842

# ── API Keys (override OS keychain) ──────────────────────────────────────────
# WIKIMIND_ANTHROPIC_API_KEY=sk-ant-...
# WIKIMIND_OPENAI_API_KEY=sk-...
# WIKIMIND_GOOGLE_API_KEY=...

# Non-prefixed names also work (CI/CD convenience):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── AWS / R2 Sync ────────────────────────────────────────────────────────────
# WIKIMIND_AWS_ACCESS_KEY_ID=...
# WIKIMIND_AWS_SECRET_ACCESS_KEY=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
