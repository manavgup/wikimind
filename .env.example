# ============================================================================
# WikiMind — Runtime Configuration
# ============================================================================
# Copy this file to `.env` at the project root and fill in the values you need.
# `.env` is gitignored — never commit your real keys.
#
# Pydantic BaseSettings reads this file automatically on server startup.
# Nested settings use the `__` delimiter:
#   WIKIMIND_LLM__OPENAI__ENABLED=true → settings.llm.openai.enabled
#
# Most users only need to set ONE LLM API key. The provider whose key is
# detected will be auto-enabled — you don't need to flip an `enabled` flag.

# ----------------------------------------------------------------------------
# LLM API Keys (set ONE — provider auto-enables)
# ----------------------------------------------------------------------------
# These work both with the WIKIMIND_ prefix and without (CI/CD friendly).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ----------------------------------------------------------------------------
# LLM Provider Selection (optional)
# ----------------------------------------------------------------------------
# If multiple keys are set, choose the default.
# WIKIMIND_LLM__DEFAULT_PROVIDER=anthropic   # anthropic | openai | google | ollama

# Allow falling back to other configured providers when the default fails
# WIKIMIND_LLM__FALLBACK_ENABLED=true

# Monthly spending ceiling across all providers (USD)
# WIKIMIND_LLM__MONTHLY_BUDGET_USD=50.0

# ----------------------------------------------------------------------------
# Per-Provider Model Overrides (optional)
# ----------------------------------------------------------------------------
# WIKIMIND_LLM__ANTHROPIC__MODEL=claude-sonnet-4-5
# WIKIMIND_LLM__OPENAI__MODEL=gpt-4o
# WIKIMIND_LLM__GOOGLE__MODEL=gemini-2.0-flash
# WIKIMIND_LLM__OLLAMA__MODEL=llama3.2

# Local Ollama endpoint (if using local models)
# WIKIMIND_LLM__OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------------------------
# Force-Enable a Provider (only needed if you want a key-less provider active)
# ----------------------------------------------------------------------------
# Auto-enable handles the common case. Use these if you want to enable Ollama
# (which doesn't need a key) or temporarily disable a provider whose key is set.
# WIKIMIND_LLM__OLLAMA__ENABLED=true
# WIKIMIND_LLM__ANTHROPIC__ENABLED=false

# ----------------------------------------------------------------------------
# AWS / R2 Sync (optional, future use)
# ----------------------------------------------------------------------------
# WIKIMIND_AWS_ACCESS_KEY_ID=...
# WIKIMIND_AWS_SECRET_ACCESS_KEY=...

# ----------------------------------------------------------------------------
# Server (optional)
# ----------------------------------------------------------------------------
# WIKIMIND_SERVER__HOST=127.0.0.1
# WIKIMIND_SERVER__PORT=7842

# ----------------------------------------------------------------------------
# Data Directory (optional)
# ----------------------------------------------------------------------------
# Defaults to ~/.wikimind. Override to put state somewhere else.
# WIKIMIND_DATA_DIR=/custom/path

# ----------------------------------------------------------------------------
# Database (optional)
# ----------------------------------------------------------------------------
# Verbose SQL query logging — dev only, very noisy
# WIKIMIND_DATABASE__ECHO=false

# ----------------------------------------------------------------------------
# Logging (optional)
# ----------------------------------------------------------------------------
# LOG_LEVEL=INFO
