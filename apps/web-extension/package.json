{
  "name": "@wikimind/web-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:build:popup -- --watch\" \"npm:build:sw -- --watch\"",
    "build": "npm run build:popup && npm run build:sw && npm run copy:manifest",
    "build:popup": "vite build",
    "build:sw": "vite build --config vite.config.sw.ts",
    "copy:manifest": "cp manifest.json dist/manifest.json && rm -rf dist/icons && cp -r public/icons dist/icons",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "preact": "^10.19.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "@testing-library/preact": "^3.2.0",
    "@types/chrome": "^0.0.260",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "jsdom": "^24.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^1.6.0"
  }
}
