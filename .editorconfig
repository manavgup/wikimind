root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{py,yaml,yml,json,toml,md,sh}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{js,ts,tsx,jsx,css,html}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
